
config smartdns
	option server_name 'smartdns'
	option tcp_server '1'
	option seconddns_tcp_server '1'
	option prefetch_domain '1'
	option dualstack_ip_selection '0'
	option seconddns_no_cache '1'
	option seconddns_port '5335'
	option seconddns_server_group 'www'
	option seconddns_no_speed_check '1'
	option port '530'
	option ipv6_server '1'
	option serve_expired '1'
	option resolve_local_hostnames '1'
	option force_https_soa '0'
	option auto_set_dnsmasq '0'
	option bind_device '1'
	option cache_persist '1'
	option cache_size '1000'
	option enabled '1'
	option rr_ttl '300'
	option rr_ttl_min '60'
	option rr_ttl_max '300'
	option tls_server '0'
	option doh_server '0'
	option log_output_mode 'file'
	option ui '1'
	option ui_port '3001'
	option old_port '530'
	option old_enabled '1'
	option old_auto_set_dnsmasq '0'

